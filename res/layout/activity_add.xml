<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="4dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:text="@string/btn_back"
            android:textColor="@color/text_on_primary"
            android:textSize="22sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/add_title"
            android:textColor="@color/text_on_primary"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_method_title"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <!-- Manual card -->
            <LinearLayout
                android:id="@+id/card_manual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_card"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="10dp"
                android:nextFocusUp="@+id/btn_back"
                android:nextFocusDown="@+id/card_camera">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="✎"
                    android:textColor="@color/primary"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:focusable="false" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:focusable="false">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_method_manual"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_method_manual_sub"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/text_hint"
                    android:focusable="false" />
            </LinearLayout>

            <!-- Camera card -->
            <LinearLayout
                android:id="@+id/card_camera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_card"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="10dp"
                android:nextFocusUp="@+id/card_manual"
                android:nextFocusDown="@+id/card_picture">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="📷"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:focusable="false" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:focusable="false">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_method_camera"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_method_camera_sub"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/text_hint"
                    android:focusable="false" />
            </LinearLayout>

            <!-- Picture card -->
            <LinearLayout
                android:id="@+id/card_picture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_card"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="20dp"
                android:nextFocusUp="@+id/card_camera"
                android:nextFocusDown="@+id/edit_name">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="🖼"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:focusable="false" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:focusable="false">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_method_picture"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_method_picture_sub"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/text_hint"
                    android:focusable="false" />
            </LinearLayout>

            <!-- Manual entry form (shown when card_manual tapped) -->
            <LinearLayout
                android:id="@+id/manual_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/edit_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_account_name"
                    android:inputType="textCapSentences"
                    android:layout_marginBottom="10dp"
                    style="@style/EditField"
                    android:nextFocusUp="@+id/card_picture"
                    android:nextFocusDown="@+id/edit_seed" />

                <EditText
                    android:id="@+id/edit_seed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_seed"
                    android:inputType="textNoSuggestions"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="14dp"
                    style="@style/EditField"
                    android:nextFocusUp="@+id/edit_name"
                    android:nextFocusDown="@+id/btn_save" />

                <Button
                    android:id="@+id/btn_save"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/btn_save"
                    style="@style/BtnPrimary"
                    android:nextFocusUp="@+id/edit_seed" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
